## Copy to .env.local and fill values

# Base de données (obligatoire) — libSQL / Turso recommandé.
# Mettre ces clés dans .env.local (prioritaire) ou .env. prisma.config.ts charge .env puis .env.local pour les commandes Prisma CLI.
# Exemple : libsql://votre-db-xxxxx.turso.io
DATABASE_URL=""
# Jeton Turso (requis pour une URL libsql:// distante).
TURSO_AUTH_TOKEN=""
# Schéma sur Turso : `npm run db:migrate:remote` (Prisma migrate deploy ne prend pas en charge libsql://).

# Anthropic
ANTHROPIC_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_DEPOSIT_AMOUNT_CENTS="2500"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# API Ninjas (Cars) — clé utilisée uniquement côté backend (jamais exposée au frontend)
API_NINJAS_KEY=""

# Admin (page /admin/diagnostics) — code demandé à chaque visite, aucun cookie
ADMIN_PIN="1234"

# Google Calendar (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Private key with \n newlines, e.g. "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""

# SMTP (emails transactionnels : inscription, confirmation compte, partenaires…)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# Optionnel : en-tête From complet (sinon PitStop + SMTP_USER). Avec Gmail, l’adresse doit correspondre au compte.
# SMTP_FROM=PitStop <pitstopbelgique@gmail.com>
PARTNER_CONTACT_TO="pitstopbelgique@gmail.com"

