## Copy to .env.local and fill values

# Prisma
DATABASE_URL="file:./dev.db"

# Anthropic
ANTHROPIC_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_DEPOSIT_AMOUNT_CENTS="2500"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# API Ninjas (Cars) — clé utilisée uniquement côté backend (jamais exposée au frontend)
API_NINJAS_KEY=""

# Admin (page /admin/diagnostics) — code demandé à chaque visite, aucun cookie
ADMIN_PIN="1234"

# Google Calendar (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Private key with \n newlines, e.g. "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""

# SMTP (email envoi formulaire partenaires)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
PARTNER_CONTACT_TO="pitstopbelgique@gmail.com"

